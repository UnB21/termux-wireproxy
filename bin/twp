#!/data/data/com.termux/files/usr/bin/bash

set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

COMMAND="${1:-help}"

case "$COMMAND" in

    start)
        "$PROJECT_DIR/scripts/start.sh"
        ;;

    stop)
        "$PROJECT_DIR/scripts/stop.sh"
        ;;

    restart)
        "$PROJECT_DIR/scripts/restart.sh"
        ;;

    status)
        "$PROJECT_DIR/scripts/status.sh"
        ;;

    health)
        "$PROJECT_DIR/scripts/health.sh"
        ;;

    current)
        "$PROJECT_DIR/scripts/current.sh"
        ;;

    version)
        echo "Termux WireProxy"
        echo "Version: $(cat "$PROJECT_DIR/VERSION")"
        ;;

    providers)
        "$PROJECT_DIR/scripts/providers.sh"
        ;;

    doctor)
        "$PROJECT_DIR/scripts/doctor.sh"
        ;;

    ip)
        "$PROJECT_DIR/scripts/ip.sh"
        ;;

    logs)
        "$PROJECT_DIR/scripts/logs.sh" "$@"
        ;;

    use)
        shift
        "$PROJECT_DIR/scripts/use.sh" "$@"
        ;;

    *)
        cat <<EOF

Termux WireProxy

Usage:

  twp start
  twp stop
  twp restart
  twp status
  twp health
  twp current
  twp providers
  twp doctor
  twp ip
  twp logs
  twp logs-f
  twp use <provider> <profile>
  twp version

Examples:

  twp use proton us.conf
  twp status
  twp health

EOF
        ;;

esac
